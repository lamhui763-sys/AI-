{
  "version": 2,
  "builds": [
    {
      "src": "src/ai_inv/web_dashboard.py",
      "use": "@vercel/python",
      "config": {
        "runtime": "python3.11"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "src/ai_inv/web_dashboard.py"
    }
  ],
  "functions": {
    "src/ai_inv/web_dashboard.py": {
      "runtime": "python3.11"
    }
  }
}